{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:live": "node --import tsx --test \"src/**/*.itest.ts\""
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.178",
    "@connectrpc/connect-node": "^1.7.0",
    "@cursor/sdk": "^1.0.19",
    "@larksuiteoapi/node-sdk": "^1.67.0",
    "cors": "^2.8.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "comment:cursor-sdk": "@cursor/sdk 故意不放进依赖：SDK 集成层以动态 import 接入并优雅降级。激活真实 SDK：npm i -w backend @cursor/sdk"
}
